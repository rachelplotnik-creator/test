# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Community Cloud, paste these under App settings → Secrets.

GOOGLE_SHEET_URL = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit"

# Paste the contents of your service-account JSON key as a TOML table.
# Every field from the downloaded JSON file goes here.
[GOOGLE_CREDENTIALS]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "abc123def456"
private_key = """-----BEGIN RSA PRIVATE KEY-----
YOUR PRIVATE KEY CONTENT HERE
-----END RSA PRIVATE KEY-----"""
client_email = "tatari-dashboard@your-project.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/tatari-dashboard%40your-project.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
