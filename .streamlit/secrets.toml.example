# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Community Cloud, paste these under App settings → Secrets.

# Airtable Base ID — find at airtable.com/developers/web/api/introduction
# (click your base; the URL will contain "appXXXXXXXXXXXXXX")
AIRTABLE_BASE_ID = "appXXXXXXXXXXXXXX"

# Personal Access Token — create at airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write
# Required access: your Tatari base
AIRTABLE_PAT = "patXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY"
